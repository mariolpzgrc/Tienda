## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build results
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio files
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Rider
.idea/

# VS Code
.vscode/

# Build outputs
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
bld/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Package Restore
packages/
*.nupkg
*.snupkg
.nuget/

# Node modules (si usas frontend)
node_modules/

# Runtime files
*.log
*.cache
*.pid
*.seed

# IIS Express
.vs/
iisexpress/

# Publish output
publish/
*.pubxml.user

# Azure
PublishScripts/

# OS files
.DS_Store
Thumbs.db

# Entity Framework
*.edmx.diagram

# SQL Server
*.mdf
*.ldf

# Temporary files
*.tmp
*.temp

# Resharper
_ReSharper*/
*.DotSettings.user

# StyleCop
StyleCopReport.xml

# dotCover
*.dotCover

# Test results
TestResults/

# Backup files
*.bak

# Web deploy
*.publishsettings

# Local appsettings
appsettings.Development.json

# wwwroot libraries (si usas LibMan o npm)
wwwroot/lib/
